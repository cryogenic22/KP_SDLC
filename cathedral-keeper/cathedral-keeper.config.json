{
  "version": "0.1.0",
  "name": "Cathedral Keeper (Default)",
  "paths": {
    "include": [],
    "extensions": [".py"],
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/output/**",
      "**/.git/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/.venv/**",
      "**/.venv*/**",
      "**/venv/**",
      "**/venv*/**",
      "**/site-packages/**",
      "**/.quality-reports/**"
    ]
  },
  "integrations": {
    "quality_gate": { "enabled": true, "qg_path": "quality-gate/quality_gate.py" },
    "external_findings_json": { "enabled": false, "argv": [], "cwd": null }
  },
  "policies": {
    "CK-PY-CYCLES": { "enabled": true, "type": "python_cycles", "severity": "high", "config": {} },
    "CK-PY-BOUNDARIES": { "enabled": false, "type": "python_boundaries", "severity": "high", "config": { "rules": [] } },
    "CK-ARCH-LAYER-DIRECTION": {
      "enabled": false,
      "severity": "high",
      "config": {
        "layers": [],
        "direction": "top-down",
        "allowed_cross_layer": []
      }
    },
    "CK-ARCH-DEAD-MODULES": {
      "enabled": true,
      "severity": "low",
      "config": {
        "entry_point_patterns": [
          "**/cli.py", "**/__main__.py", "**/conftest.py", "**/test_*.py",
          "**/*_test.py", "**/tests/**", "**/test/**", "**/celery_*.py",
          "**/migrations/**", "**/alembic/**", "**/manage.py", "**/setup.py",
          "**/tasks.py", "**/__init__.py"
        ]
      }
    },
    "CK-ARCH-DRIFT": {
      "enabled": false,
      "severity": "medium",
      "config": {
        "baseline_path": ".quality-reports/cathedral-keeper/baseline.json",
        "warn_threshold": 10,
        "fail_threshold": 25
      }
    },
    "CK-ARCH-SERVICE-BOUNDARIES": {
      "enabled": false,
      "severity": "high",
      "config": {
        "services": [],
        "allow_shared": ["**/shared/**", "**/common/**", "**/models/**"]
      }
    },
    "CK-ARCH-CONFIG-SPRAWL": {
      "enabled": false,
      "severity": "medium",
      "config": {
        "settings_modules": ["**/settings.py", "**/config.py"],
        "allow_direct_env": ["**/settings.py", "**/config.py", "**/conftest.py"]
      }
    },
    "CK-ARCH-TEST-ALIGNMENT": {
      "enabled": false,
      "severity": "low",
      "config": {
        "source_roots": [],
        "test_roots": ["tests"],
        "test_pattern": "test_{module}.py",
        "require_boundary_tests": true,
        "require_llm_evals": false
      }
    },
    "CK-ARCH-ENV-PARITY": {
      "enabled": false,
      "severity": "low",
      "config": {
        "env_docs": [".env.example"],
        "flag_conditional_env": true,
        "ignore_keys": ["PATH", "HOME", "USER", "PYTHONPATH"]
      }
    },
    "CK-ARCH-DEPENDENCY-HEALTH": {
      "enabled": false,
      "severity": "info",
      "config": {
        "dependency_files": ["requirements.txt", "pyproject.toml", "requirements-dev.txt"],
        "overlap_categories": {
          "http_client": ["requests", "httpx", "aiohttp", "urllib3"],
          "orm": ["sqlalchemy", "tortoise-orm", "peewee", "django"],
          "mongo": ["pymongo", "mongoengine", "motor"],
          "task_queue": ["celery", "dramatiq", "rq", "huey"]
        }
      }
    },
    "CK-BLAST-RADIUS": {
      "enabled": false,
      "severity": "medium",
      "_description": "Blast-radius analysis: BFS on reverse import edges from changed files. Flags high fan-in files and reports affected dependents + tests.",
      "config": {
        "max_depth": 3,
        "fan_in_threshold": 10
      }
    },
    "CK-ARCH-TEST-COVERAGE": {
      "enabled": false,
      "severity": "low",
      "_description": "TESTED_BY edge detection: analyzes test file imports to find source files with zero test coverage (no test file imports them).",
      "config": {
        "exclude_patterns": ["**/__init__.py", "**/conftest.py", "**/migrations/**"]
      }
    },
    "CK-COHERENCE": {
      "enabled": false,
      "severity": "medium",
      "_description": "Cross-metric coherence: flags when QG and CK metrics diverge (e.g., PRS avg >90 but CK has >10 high-severity findings). Catches measurement system failures.",
      "config": {
        "prs_high_threshold": 90.0,
        "ck_high_severity_threshold": 10,
        "suspiciously_clean_file_threshold": 20,
        "finding_drop_pct": 50.0
      }
    },
    "CK-RED-TEAM": {
      "enabled": false,
      "severity": "medium",
      "_description": "Adversarial sanity checks: RT1 finding-count drop, RT2 suspiciously high PRS, RT3 zero findings on large codebase, RT4 god module detection.",
      "config": {
        "drop_threshold_pct": 50.0,
        "prs_high_threshold": 95.0,
        "zero_finding_file_threshold": 500,
        "blast_radius_pct_threshold": 50.0
      }
    }
  },
  "reporting": { "top_findings": 50, "top_files": 30 },
  "thresholds": { "fail_on_severity_at_or_above": "high" }
}
