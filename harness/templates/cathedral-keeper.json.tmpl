      "**/.venv/**",
      "**/.venv*/**",
      "**/venv/**",
      "**/venv*/**",
      "**/site-packages/**",
      "**/.quality-reports/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "output/**",
      ".venv/**",
      ".venv*/**",
      "venv/**",
      "venv*/**",
      "tools/qa/**"
    ]
  },
  "integrations": {
    "_note": "The vendored layout puts QG under tools/qa/ — without this override CK looks for quality-gate/quality_gate.py and emits 'Quality Gate script not found'.",
    "quality_gate": {
      "enabled": true,
      "qg_path": "tools/qa/quality-gate/quality_gate.py"
    }
  }
