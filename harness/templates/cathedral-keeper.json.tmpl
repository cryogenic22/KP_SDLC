{
  "_note": "Repo Cathedral Keeper override — deep-merged over the vendored tools/qa/cathedral-keeper/cathedral-keeper.config.json. Shipped by sdlc init; protected by CODEOWNERS (protected-surface.txt).",
  "paths": {
    "_note_lists_replace": "Deep-merge REPLACES lists: setting paths.exclude here discards the portable defaults, so they are restated in full below before adding the repo-specific entries.",
