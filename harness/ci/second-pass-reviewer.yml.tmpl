# Second-pass reviewer — fresh-context Claude review against design-philosophy.
# Bootstrapped from kp-sdlc/harness on {{BOOTSTRAP_DATE}}.
#
# Independent review: a separate Claude session sees only the PR diff and the
# 22-flag Tier 2 checklist. No prior context, no chat history. Catches what
# the first-pass agent's drift missed.
#
# Required secret: ANTHROPIC_API_KEY (workflow auto-skips if absent).
# Cost: ~$0.05–0.20 per PR depending on diff size.
name: second-pass-reviewer

on:
  pull_request:
    branches: [main]

permissions:
  contents: read
  pull-requests: write

concurrency:
  group: second-pass-${{ github.ref }}
  cancel-in-progress: true

jobs:
  review:
    name: Fresh-context review against design-philosophy
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Check for ANTHROPIC_API_KEY
        id: keycheck
        env:
          HAS_KEY: ${{ secrets.ANTHROPIC_API_KEY != '' }}
        run: echo "has_key=$HAS_KEY" >> "$GITHUB_OUTPUT"

      - name: Run second-pass reviewer
        if: steps.keycheck.outputs.has_key == 'true'
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          python .harness/hooks/second_pass_reviewer.py \
            --base "${{ github.event.pull_request.base.sha }}" \
            --head "${{ github.event.pull_request.head.sha }}" \
            --principles .claude/skills/design-philosophy/SKILL.md \
            > review.md
          echo "review_exists=true" >> "$GITHUB_ENV"

      - name: Post review as PR comment
        if: env.review_exists == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const review = fs.readFileSync('review.md', 'utf8');
            const body = [
              '## Second-pass review',
              '',
              '_Independent fresh-context Claude review — no prior context on this PR or codebase. Reviews against `.claude/skills/design-philosophy/SKILL.md` Tier 2 (22 red flags)._',
              '',
              review,
              '',
              '_If this review contradicts the author\'s Self-review attestation, flag it for human inspection._'
            ].join('\n');
            github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body
            });

      - name: Skip notice
        if: steps.keycheck.outputs.has_key != 'true'
        run: |
          echo "ANTHROPIC_API_KEY not set in repo secrets — skipping second-pass review."
          echo "Add it via: Settings → Secrets and variables → Actions → New repository secret."
