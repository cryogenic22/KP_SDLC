# KP_SDLC Configuration
# =====================
# Copy this file to .env and fill in your values.
# This file is loaded automatically by QG, CK, Fix Engine, and Reporting.

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# API Keys — set the one for your chosen provider
# Get your key from: https://console.anthropic.com/settings/keys
# or: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Model Selection
# Anthropic: claude-sonnet-4-5-20250514, claude-haiku-4-5-20251001, claude-opus-4-0-20250514
# OpenAI: gpt-4o, gpt-4o-mini, o1-mini
LLM_MODEL=claude-sonnet-4-5-20250514

# LLM Fix Settings
LLM_MAX_TOKENS=1024
LLM_MAX_FIXES_PER_RUN=20
LLM_TIMEOUT=30
